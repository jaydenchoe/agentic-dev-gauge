# Server
HOST=0.0.0.0
PORT=8080

# System Metrics
METRICS_INTERVAL_SEC=2
METRICS_BACKEND=auto  # auto | psutil | macmon

# AI Usage API Keys (optional)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GITHUB_TOKEN=
CODEX_API_KEY=
ZHIPUAI_API_KEY=
GEMINI_API_KEY=

# Usage polling
USAGE_INTERVAL_SEC=60

# Chrome debug profile for CDP (claude.ai usage scraping)
CHROME_DEBUG_PROFILE_DIR=~/.tiny-monitor/chrome-debug-profile
CHROME_DEBUG_PORT=9222
CHROME_DEBUG_AUTO_LAUNCH=true

# Thresholds (JSON string)
THRESHOLDS='[{"metric":"cpu_percent","warning":80,"critical":95},{"metric":"memory_percent","warning":80,"critical":95},{"metric":"disk_percent","warning":85,"critical":95},{"metric":"token_cost","warning":10.0,"critical":50.0}]'

# OpenClaw Gateway (optional)
OPENCLAW_GATEWAY_URL=
OPENCLAW_API_KEY=

# GeekMagic SmallTV Ultra external display — leave blank to disable
GEEKMAGIC_ULTRA_URL=http://192.168.150.113
GEEKMAGIC_INTERVAL_SEC=5
